# ===========================================
# .gitignore for DeskMCP
# ===========================================

# -------------------------------------------
# 1. プライバシーに係る情報が含まれるファイル
# -------------------------------------------

# 設定ファイル（API キー、エンドポイント等が含まれる可能性）
config/
*.config.json
*.config.yaml
*.config.yml
*.env
.env.*

# データベースファイル（タスクデータ等）
*.db
*.db.backup.*
*.sqlite
*.sqlite3

# ログファイル
*.log
*.log.*
logs/

# バックアップファイル
*.backup
*.backup.*
*.bak
*~

# -------------------------------------------
# 4. Chainlit関連
# -------------------------------------------
.chainlit/
.files/

# -------------------------------------------
# 5. Python標準イグノア
# -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
*.egg

# -------------------------------------------
# 6. IDE/エディタ
# -------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -------------------------------------------
# その他の一般的なイグノア
# -------------------------------------------
.DS_Store
Thumbs.db
*.tmp
*.temp
default_mcp_server/DeskToDo/desktodo_config.yaml
